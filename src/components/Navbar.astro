---
import LanguageSwitcher from "./LanguageSwitcher.astro";
---

<nav class="fixed top-0 w-full z-50 glass border-b border-slate-700/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex-shrink-0 font-bold text-xl text-white tracking-wider">
        FMENDEZ<span class="text-blue-500">.dev</span>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-5">
          <button
            data-tab-target="#inicio"
            class="nav-link active px-3 py-2 rounded-md text-sm font-medium"
            data-i18n="nav_home">Home</button
          >
          <button
            data-tab-target="#habilidades"
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-400 hover:text-white"
            data-i18n="nav_skills">Skills</button
          >
          <button
            data-tab-target="#experiencia"
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-400 hover:text-white"
            data-i18n="nav_projects">Projects</button
          >
          <button
            data-tab-target="#educacion"
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-400 hover:text-white"
            data-i18n="nav_education">Education</button
          >
          <button
            data-tab-target="#contacto"
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-gray-400 hover:text-white"
            data-i18n="nav_contact">Contact</button
          >
        </div>
      </div>

      <!-- Desktop Language Switcher -->
      <LanguageSwitcher variant="desktop" />

      <!-- Mobile menu button -->
      <div class="-mr-2 flex md:hidden">
        <button
          type="button"
          id="mobile-menu-btn"
          class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-slate-800 focus:outline-none"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <svg
            class="block h-6 w-6"
            id="menu-icon-closed"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            class="hidden h-6 w-6"
            id="menu-icon-open"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    class="hidden md:hidden glass border-t border-slate-700/30"
    id="mobile-menu"
  >
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <button
        data-tab-target="#inicio"
        class="mobile-nav-link block w-full text-left px-3 py-2 rounded-md text-base font-medium text-white bg-slate-800"
        data-i18n="nav_home">Home</button
      >
      <button
        data-tab-target="#habilidades"
        class="mobile-nav-link block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-slate-800"
        data-i18n="nav_skills">Skills</button
      >
      <button
        data-tab-target="#experiencia"
        class="mobile-nav-link block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-slate-800"
        data-i18n="nav_projects">Projects</button
      >
      <button
        data-tab-target="#educacion"
        class="mobile-nav-link block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-slate-800"
        data-i18n="nav_education">Education</button
      >
      <button
        data-tab-target="#contacto"
        class="mobile-nav-link block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-slate-800"
        data-i18n="nav_contact">Contact</button
      >

      <!-- Mobile Language Switcher -->
      <LanguageSwitcher variant="mobile" />
    </div>
  </div>
</nav>
