---
/**
 * Hero.astro
 * Hero section with greeting, typewriter effect, description, and terminal card.
 */
import TerminalCard from "./TerminalCard.astro";
---

<section id="inicio" data-tab-content class="active tab-content">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <!-- Hero Text -->
    <div class="lg:col-span-12 text-center mb-10 mt-5">
      <p
        class="text-blue-500 font-medium mb-2 tracking-wide uppercase text-sm animate-fade-in"
        data-i18n="hero_greeting"
      >
        Hello, I am
      </p>
      <h1
        class="text-5xl md:text-7xl font-bold text-white mb-4 animate-fade-in delay-100"
      >
        Facundo Mendez
      </h1>
      <h2
        class="text-2xl md:text-3xl text-gray-400 font-light mb-8 animate-fade-in delay-200 h-8"
      >
        <span id="typewriter-text" class="text-gradient font-semibold"></span>
        <span class="cursor"></span>
      </h2>
      <p
        class="max-w-3xl mx-auto text-lg text-gray-400 leading-relaxed animate-fade-in delay-300"
        data-i18n="hero_description"
      >
        I am an Advanced Systems Student, passionate about the world of Backend
        and Infrastructure. My technical background comes from industrial
        automation, giving me a pragmatic mindset for problem-solving and
        process optimization. Currently, I apply agile methodologies to build
        robust solutions integrating AWS services and Linux environments
      </p>
    </div>

    <!-- Terminal -->
    <div class="lg:col-span-12 animate-fade-in delay-300">
      <TerminalCard />
    </div>
  </div>
</section>
