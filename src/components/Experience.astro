---
/**
 * Experience.astro
 * Work experience card shown in the "profesional" inner tab.
 */
interface Props {}
---

<div
  class="glass-card p-6 rounded-xl border-l-4 border-blue-600 relative overflow-hidden"
>
  <div class="absolute top-0 right-0 p-4 opacity-5">
    <img
      src="https://img.icons8.com/ios-filled/100/ffffff/server.png"
      alt="server"
    />
  </div>
  <div class="md:flex justify-between items-start mb-4">
    <div>
      <h3 class="text-xl font-bold text-white" data-i18n="exp_job_title">
        Technical Operator (Automation/SCADA)
      </h3>
      <p class="text-blue-400">INEVH "Dr. Julio I. Maiztegui"</p>
    </div>
    <span
      class="text-sm bg-slate-800 px-3 py-1 rounded-full text-gray-400 mt-2 md:mt-0 inline-block"
    >
      Jan 2023 - Present
    </span>
  </div>

  <ul
    class="space-y-3 text-gray-300 text-sm marker:text-blue-500 list-disc list-inside"
  >
    <li data-i18n="exp_job_desc_1">
      <span class="text-white font-medium">Automation:</span> PLC automation, reducing
      manual operations by 40% and freeing up 5 hrs/week.
    </li>
    <li data-i18n="exp_job_desc_2">
      <span class="text-white font-medium">Documentation:</span> Standardized processes
      with 15+ SOPs in LOYAL system improving traceability.
    </li>
    <li data-i18n="exp_job_desc_3">
      <span class="text-white font-medium">Monitoring:</span> Instrumented monitoring
      and alerts in SCADA/HVAC, reducing response times for critical events.
    </li>
    <li data-i18n="exp_job_desc_4">
      <span class="text-white font-medium">DevOps:</span> Containerized a test environment
      with Docker/Compose.
    </li>
  </ul>
</div>
