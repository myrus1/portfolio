---
/**
 * TerminalCard.astro
 * Simulated terminal display showing profile data as JSON.
 */
---

<div
  class="bg-slate-900 rounded-lg shadow-2xl overflow-hidden border border-slate-700 font-mono text-sm md:text-base mx-auto max-w-4xl"
>
  <!-- Terminal Header -->
  <div
    class="bg-slate-800 px-4 py-2 flex items-center gap-2 border-b border-slate-700"
  >
    <div class="w-3 h-3 rounded-full bg-red-500"></div>
    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
    <div class="w-3 h-3 rounded-full bg-green-500"></div>
    <span class="ml-2 text-xs text-gray-400" data-i18n="terminal_user"
      >facundo@devops:~/profile</span
    >
  </div>

  <!-- Terminal Body -->
  <div class="p-6 text-gray-300 space-y-4">
    <div>
      <span class="text-green-400">facundo@devops</span>:<span
        class="text-blue-400">~</span
      >$ cat profile.json
    </div>
    <div class="pl-4 text-emerald-300">
      {`{`}<br />
      &nbsp;&nbsp;"role": "DevOps Junior",<br />
      &nbsp;&nbsp;"location": "Pergamino, Buenos Aires, AR",<br />
      &nbsp;&nbsp;"email": "mendezfacundo80@gmail.com",<br />
      &nbsp;&nbsp;"focus": ["AWS", "Docker", "Automation", "Linux"],<br />
      &nbsp;&nbsp;"current_learning": ["Terraform", "Kubernetes"]<br />
      {`}`}
    </div>
    <div>
      <span class="text-green-400">facundo@devops</span>:<span
        class="text-blue-400">~</span
      >$
      <span class="animate-pulse">_</span>
    </div>
  </div>
</div>
