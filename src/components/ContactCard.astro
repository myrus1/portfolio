---
/**
 * ContactCard.astro
 * Individual contact method card (LinkedIn, GitHub, Email, etc.)
 */
interface Props {
  href: string;
  title: string;
  actionText: string;
  actionI18n: string;
  iconBg: string; // e.g. 'bg-blue-600'
  shadowColor: string; // e.g. 'shadow-blue-600/30'
  hoverBg: string; // e.g. 'hover:bg-blue-900/20'
  actionColor: string; // e.g. 'text-blue-400'
}

const {
  href,
  title,
  actionText,
  actionI18n,
  iconBg,
  shadowColor,
  hoverBg,
  actionColor,
} = Astro.props;
---

<a
  href={href}
  target="_blank"
  class={`group glass-card p-8 rounded-2xl ${hoverBg} transition-all duration-300`}
>
  <div
    class={`w-16 h-16 mx-auto ${iconBg} rounded-full flex items-center justify-center mb-6 shadow-lg ${shadowColor} group-hover:scale-110 transition-transform`}
  >
    <slot />
  </div>
  <h3 class="text-xl font-bold text-white mb-2">{title}</h3>
  <p class={`${actionColor} text-sm`} data-i18n={actionI18n}>{actionText}</p>
</a>
